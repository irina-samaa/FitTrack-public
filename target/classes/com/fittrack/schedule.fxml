<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fittrack.controller.ScheduleController"
      spacing="16"
      style="-fx-padding: 24; -fx-background-color: #0F0F0F;">

    <Label text="Schedule" styleClass="screen-title" />

    <Label fx:id="nextReminderLabel"
           styleClass="card-subtitle"
           style="-fx-text-fill: #00E5FF; -fx-font-size: 14;" />

    <VBox styleClass="card" spacing="8" VBox.vgrow="ALWAYS">
        <Label text="BODY PART REMINDERS" styleClass="card-title-accent" />

        <TableView fx:id="reminderTable"
                   styleClass="dark-table"
                   VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="labelColumn" text="Body Part" minWidth="180" />
                <TableColumn fx:id="timeColumn" text="Status" minWidth="360" />
                <TableColumn fx:id="noteColumn" text="Note" minWidth="220" />
            </columns>
            <placeholder>
                <Label text="No started reminders yet. Log a workout to begin countdowns."
                       style="-fx-text-fill: #666;" />
            </placeholder>
        </TableView>
    </VBox>

    <VBox styleClass="card" spacing="10">
        <Label text="UPDATE REMINDER" styleClass="card-title-accent" />

        <Label text="Countdown starts automatically after the first logged workout for that body part."
               styleClass="card-subtitle"
               wrapText="true" />

        <GridPane hgap="16" vgap="14" styleClass="reminder-form-grid">
            <columnConstraints>
                <ColumnConstraints percentWidth="50" hgrow="ALWAYS" />
                <ColumnConstraints percentWidth="50" hgrow="ALWAYS" />
            </columnConstraints>

            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="BODY PART" styleClass="field-label" />
                <ComboBox fx:id="bodyPartComboBox"
                          promptText="Select body part"
                          maxWidth="Infinity"
                          styleClass="dark-combo" />
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="THRESHOLD DAYS" styleClass="field-label" />
                <TextField fx:id="thresholdDaysField"
                           promptText="Leave blank for 5"
                           maxWidth="Infinity"
                           styleClass="dark-input" />
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                <Label text="NOTE (OPTIONAL)" styleClass="field-label" />
                <TextField fx:id="reminderNoteField"
                           promptText="Add a short note..."
                           maxWidth="Infinity"
                           styleClass="dark-input" />
            </VBox>

            <HBox alignment="CENTER_RIGHT" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                <Button text="Save Changes"
                        styleClass="primary-button"
                        onAction="#saveReminder"
                        style="-fx-padding: 8 20;" />
            </HBox>
        </GridPane>
    </VBox>

</VBox>
