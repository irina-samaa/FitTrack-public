<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fittrack.controller.HealthController"
      spacing="14"
      style="-fx-padding: 24; -fx-background-color: #0F0F0F;">

    <HBox alignment="CENTER_LEFT" spacing="18">
        <Label text="Health Metrics" styleClass="screen-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="currentWeightLabel" styleClass="subtitle-text" />
        <Label fx:id="currentHeightLabel" styleClass="subtitle-text" />
    </HBox>

    <VBox styleClass="card" spacing="12" maxHeight="130">
        <Label text="UPDATE MEASUREMENTS" styleClass="card-title-accent" />
        <GridPane hgap="14" vgap="8">
            <columnConstraints>
                <ColumnConstraints percentWidth="38" />
                <ColumnConstraints percentWidth="38" />
                <ColumnConstraints percentWidth="24" />
            </columnConstraints>

            <Label text="WEIGHT (kg)" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label text="HEIGHT (cm)" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <TextField fx:id="weightField"
                       promptText="Weight"
                       styleClass="dark-input"
                       maxWidth="Infinity"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="1" />
            <TextField fx:id="heightField"
                       promptText="Height"
                       styleClass="dark-input"
                       maxWidth="Infinity"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="1" />
            <Button text="Update"
                    styleClass="primary-button"
                    maxWidth="Infinity"
                    onAction="#handleUpdate"
                    GridPane.columnIndex="2"
                    GridPane.rowIndex="1" />
        </GridPane>
    </VBox>

    <HBox spacing="14" fillHeight="true" VBox.vgrow="ALWAYS">
        <VBox styleClass="card" spacing="10" alignment="CENTER"
              minWidth="220" prefWidth="260" maxHeight="Infinity">
            <Label text="BMI" styleClass="card-title-accent" />
            <Label fx:id="bmiResultLabel"
                   styleClass="bmi-number"
                   style="-fx-font-size: 52; -fx-font-weight: bold; -fx-text-fill: #FF4500;" />
            <Label fx:id="bmiCategoryBadge" text="-" />
        </VBox>

        <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label text="RECOMMENDATION" styleClass="card-title-accent" />
            <Label fx:id="recommendationLabel"
                   styleClass="body-text"
                   wrapText="true"
                   style="-fx-font-size: 15; -fx-text-fill: #AAAAAA;" />
            <Separator />
            <GridPane hgap="18" vgap="8">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" />
                    <ColumnConstraints percentWidth="50" />
                </columnConstraints>
                <Label text="&lt; 18.5 -> Underweight" style="-fx-text-fill: #00E5FF; -fx-font-size: 12;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Label text="18.5 - 24.9 -> Normal" style="-fx-text-fill: #39FF14; -fx-font-size: 12;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <Label text="25 - 29.9 -> Overweight" style="-fx-text-fill: #FFD700; -fx-font-size: 12;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Label text="&gt;= 30 -> Obese" style="-fx-text-fill: #FF4500; -fx-font-size: 12;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            </GridPane>
        </VBox>
    </HBox>
</VBox>
