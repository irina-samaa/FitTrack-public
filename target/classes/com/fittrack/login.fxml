<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--
  login.fxml - Popup login screen.
  Controller: LoginController.java
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fittrack.controller.LoginController"
      styleClass="dark-panel"
      alignment="CENTER"
      spacing="16"
      style="-fx-padding: 40; -fx-background-color: #0F0F0F;">

    <!-- Logo / App Name -->
    <Label text="🔥 FitTrack" styleClass="app-title" />
    <Label text="Your personal fitness companion" styleClass="subtitle-text" />

    <Separator style="-fx-background-color: #333; -fx-padding: 4 0;" />

    <!-- Username Field -->
    <VBox spacing="4">
        <Label text="USERNAME" styleClass="field-label" />
        <TextField fx:id="usernameField"
                   promptText="Enter username"
                   styleClass="dark-input"
                   onKeyTyped="#clearError" />
    </VBox>

    <!-- Password Field -->
    <VBox spacing="4">
        <Label text="PASSWORD" styleClass="field-label" />
        <PasswordField fx:id="passwordField"
                       promptText="Enter password"
                       styleClass="dark-input"
                       onKeyTyped="#clearError"
                       onAction="#handleLogin" />
    </VBox>

    <!-- Error message - hidden by default -->
    <Label fx:id="errorLabel"
           text="Invalid credentials"
           styleClass="error-label"
           visible="false"
           managed="false" />
    <!-- managed="false" keeps it from taking up layout space when hidden -->

    <!-- Login Button -->
    <Button text="LOGIN"
            styleClass="primary-button"
            onAction="#handleLogin"
            maxWidth="Infinity"
            defaultButton="true" />

    <Button text="CREATE ACCOUNT"
            styleClass="accent-button"
            onAction="#handleCreateAccount"
            maxWidth="Infinity" />

    <Label text="Seeded accounts: admin / 1234 and testuser / 1234"
           styleClass="hint-text"
           style="-fx-text-fill: #555;" />

</VBox>
