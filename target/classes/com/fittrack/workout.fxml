<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fittrack.controller.WorkoutController"
      spacing="16"
      style="-fx-padding: 24; -fx-background-color: #0F0F0F;">

    <Label text="Workout Builder" styleClass="screen-title" />

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="SESSION NAME" styleClass="field-label" />
            <TextField fx:id="sessionNameField"
                       promptText="Workout session name..."
                       styleClass="dark-input"
                       maxWidth="320" />
        </VBox>
        <Button text="Start Workout Session"
                styleClass="primary-button"
                onAction="#startWorkoutSession" />
    </HBox>

    <FlowPane hgap="12" vgap="12" prefWrapLength="1020" VBox.vgrow="ALWAYS">
        <VBox styleClass="card" spacing="8" minWidth="220" prefWidth="260">
            <Label text="BODY PARTS" styleClass="card-title-accent" />
            <ListView fx:id="bodyPartListView"
                      styleClass="dark-list"
                      VBox.vgrow="ALWAYS" />
            <HBox spacing="6">
                <TextField fx:id="newBodyPartField"
                           promptText="Body part name..."
                           styleClass="dark-input"
                           HBox.hgrow="ALWAYS" />
                <Button text="+"
                        styleClass="accent-button"
                        onAction="#addBodyPart" />
            </HBox>
        </VBox>

        <VBox styleClass="card" spacing="8" minWidth="280" prefWidth="320">
            <Label fx:id="selectedBodyPartLabel"
                   text="EXERCISES"
                   styleClass="card-title-accent" />
            <ListView fx:id="exerciseListView"
                      styleClass="dark-list"
                      VBox.vgrow="ALWAYS" />
            <HBox spacing="6">
                <TextField fx:id="newExerciseField"
                           promptText="Exercise name..."
                           styleClass="dark-input"
                           HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="exerciseTypeComboBox"
                          styleClass="dark-combo"
                          prefWidth="120" />
                <Button text="+"
                        styleClass="accent-button"
                        onAction="#addExercise" />
            </HBox>
        </VBox>

        <VBox styleClass="card" spacing="8" minWidth="380" prefWidth="460">
            <Label fx:id="selectedExerciseLabel"
                   text="SETS"
                   styleClass="card-title-accent" />

            <TableView fx:id="setTableView"
                       styleClass="dark-table"
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="setTypeColumn" text="Type" minWidth="80" />
                    <TableColumn fx:id="primaryMetricColumn" text="Metric 1" minWidth="95" />
                    <TableColumn fx:id="secondaryMetricColumn" text="Metric 2" minWidth="105" />
                    <TableColumn fx:id="workloadColumn" text="Exercise Total" minWidth="110" />
                </columns>
            </TableView>

            <Label fx:id="totalVolumeLabel"
                   text="Session workload: -"
                   styleClass="subtitle-text"
                   style="-fx-text-fill: #00E5FF;" />

            <HBox spacing="6" alignment="BOTTOM_LEFT">
                <VBox spacing="4">
                    <Label fx:id="firstMetricLabel" text="Metric 1" styleClass="field-label" />
                    <TextField fx:id="firstMetricField"
                               promptText="Metric 1"
                               styleClass="dark-input"
                               prefWidth="100" />
                </VBox>
                <VBox spacing="4">
                    <Label fx:id="secondMetricLabel" text="Metric 2" styleClass="field-label" />
                    <TextField fx:id="secondMetricField"
                               promptText="Metric 2"
                               styleClass="dark-input"
                               prefWidth="120" />
                </VBox>
                <Button text="+"
                        styleClass="accent-button"
                        prefWidth="90"
                        onAction="#addSet" />
                <Button text="Delete"
                        styleClass="danger-button"
                        prefWidth="90"
                        onAction="#deleteSet" />
            </HBox>
        </VBox>
    </FlowPane>
</VBox>
