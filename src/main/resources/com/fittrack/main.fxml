<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  main.fxml - Main window with a sidebar and content area.
  Controller: MainController.java
  Layout: BorderPane (LEFT = sidebar, TOP = top bar, CENTER = content)
-->
<BorderPane fx:id="mainPane" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.fittrack.controller.MainController"
            style="-fx-background-color: #0F0F0F;">

    <!-- ===== TOP BAR ===== -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
            <!-- App name on the left -->
            <Label text="FitTrack" styleClass="app-title-small" />

            <!-- Spacer that pushes the username and buttons to the right -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Username -->
            <Label fx:id="usernameLabel" styleClass="username-label" />

            <!-- Settings button -->
            <Button text="⚙" styleClass="icon-button" onAction="#openSettings" />

            <!-- Logout button -->
            <Button text="🚪 Logout" styleClass="danger-button" onAction="#handleLogout" />
        </HBox>
    </top>

    <!-- ===== SIDEBAR (LEFT) ===== -->
    <left>
        <VBox styleClass="sidebar" spacing="4" style="-fx-padding: 16 8;">

            <!-- Navigation buttons - each one calls navigateTo() in MainController -->
            <Button text="🏠  Home"
                    styleClass="sidebar-button"
                    maxWidth="Infinity"
                    onAction="#goHome" />

            <Button text="💪  Workout"
                    styleClass="sidebar-button"
                    maxWidth="Infinity"
                    onAction="#goWorkout" />

            <Button text="📅  Schedule"
                    styleClass="sidebar-button"
                    maxWidth="Infinity"
                    onAction="#goSchedule" />

            <Button text="❤  Health"
                    styleClass="sidebar-button"
                    maxWidth="Infinity"
                    onAction="#goHealth" />

            <Button text="📈  Progress"
                    styleClass="sidebar-button"
                    maxWidth="Infinity"
                    onAction="#goProgress" />

            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </left>

    <!-- ===== CENTER: Content area - swapped by MainController.navigateTo() ===== -->
    <center>
        <!--
          This area is replaced dynamically with:
          - dashboard.fxml (default)
          - workout.fxml
          - schedule.fxml
          - health.fxml
          - progress.fxml
          See MainController.navigateTo() for the loading flow.
        -->
        <StackPane fx:id="contentArea" style="-fx-background-color: #0F0F0F;" />
    </center>

</BorderPane>
