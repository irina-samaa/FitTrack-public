<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.fittrack.controller.DashboardController"
            fitToWidth="true" style="-fx-background-color: #0F0F0F; -fx-background: #0F0F0F;">
    <VBox spacing="24" style="-fx-padding: 32; -fx-background-color: #0F0F0F;">

        <Label text="Dashboard" styleClass="screen-title" />
        <Label text="Here's your fitness overview for today."
               styleClass="subtitle-text" />

        <HBox spacing="20">
            <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                <Label text="TODAY'S WORKOUT" styleClass="card-title-accent" />
                <Label fx:id="sessionCountLabel" styleClass="card-big-number" />
                <Label fx:id="lastSessionLabel" styleClass="card-subtitle" />
            </VBox>

            <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                <Label text="CURRENT BMI" styleClass="card-title-accent" />
                <Label fx:id="bmiValueLabel" styleClass="card-big-number" />
                <Label fx:id="bmiCategoryLabel" styleClass="card-subtitle" />
            </VBox>

            <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                <Label text="NEXT REMINDER" styleClass="card-title-accent" />
                <Label fx:id="nextReminderLabel" styleClass="card-subtitle" wrapText="true" />
            </VBox>
        </HBox>

        <VBox styleClass="card" spacing="8" style="-fx-background-color: #1a0a00; -fx-border-color: #FF4500;">
            <Label text="DAILY MOTIVATION" styleClass="card-title-accent" />
            <Label fx:id="motivationLabel" styleClass="motivation-text" wrapText="true" />
        </VBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                <Label text="EXERCISE WORKLOADS" styleClass="card-title-accent" />
                <ListView fx:id="exerciseWorkloadsListView" prefHeight="150" 
                          style="-fx-background-color: transparent; -fx-control-inner-background: #1A1A1A; -fx-text-fill: white;" />
            </VBox>
            <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                <Label text="SESSION WORKLOADS" styleClass="card-title-accent" />
                <ListView fx:id="sessionWorkloadsListView" prefHeight="150" 
                          style="-fx-background-color: transparent; -fx-control-inner-background: #1A1A1A; -fx-text-fill: white;" />
            </VBox>
        </HBox>

        <VBox styleClass="card" spacing="12">
            <Label text="4 OOP PRINCIPLES IN THIS PROJECT" styleClass="card-title-accent" />
            <Label fx:id="encapsulationLabel" styleClass="body-text" wrapText="true" />
            <Label fx:id="inheritanceLabel" styleClass="body-text" wrapText="true" />
            <Label fx:id="polymorphismLabel" styleClass="body-text" wrapText="true" />
            <Label fx:id="abstractionLabel" styleClass="body-text" wrapText="true" />
        </VBox>
    </VBox>
</ScrollPane>
