<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fittrack.controller.ScheduleController"
      spacing="16"
      style="-fx-padding: 24; -fx-background-color: #0F0F0F;">

    <Label text="Schedule" styleClass="screen-title" />

    <Label fx:id="nextReminderLabel"
           styleClass="card-subtitle"
           style="-fx-text-fill: #00E5FF; -fx-font-size: 14;" />

    <VBox styleClass="card" spacing="8" VBox.vgrow="ALWAYS">
        <Label text="BODY PART REMINDERS" styleClass="card-title-accent" />

        <TableView fx:id="reminderTable"
                   styleClass="dark-table"
                   VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="bodyPartColumn" text="Body Part" minWidth="200" />
                <TableColumn fx:id="intervalColumn" text="Reminder Days" minWidth="160" />
                <TableColumn fx:id="timeColumn" text="Next Reminder" minWidth="220" />
            </columns>
            <placeholder>
                <Label text="No reminders yet. Log a workout session first."
                       style="-fx-text-fill: #666;" />
            </placeholder>
        </TableView>
    </VBox>

    <VBox styleClass="card" spacing="10">
        <Label text="CHANGE REMINDER DAYS" styleClass="card-title-accent" />

        <HBox alignment="BOTTOM_LEFT" spacing="12">
            <VBox spacing="4" minWidth="220" prefWidth="260">
                <Label text="BODY PART" styleClass="field-label" />
                <ComboBox fx:id="bodyPartComboBox"
                          editable="true"
                          promptText="Choose body part..."
                          styleClass="dark-combo"
                          maxWidth="Infinity"
                          prefHeight="42" />
            </VBox>

            <VBox spacing="4" minWidth="220" prefWidth="260">
                <Label text="REMIND AFTER (DAYS)" styleClass="field-label" />
                <TextField fx:id="reminderDaysField"
                           promptText="Default: 5"
                           styleClass="dark-input"
                           prefHeight="42" />
            </VBox>

            <Button text="Update"
                    styleClass="primary-button"
                    onAction="#updateReminderDays"
                    minHeight="42"
                    prefHeight="42"
                    style="-fx-padding: 8 20;" />
        </HBox>
    </VBox>

</VBox>
