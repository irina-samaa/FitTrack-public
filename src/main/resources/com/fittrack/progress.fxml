<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fittrack.controller.ProgressController"
      spacing="12"
      style="-fx-padding: 20; -fx-background-color: #0F0F0F;">

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Progress" styleClass="screen-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="MOVING AVG:" styleClass="field-label" />
        <ComboBox fx:id="windowComboBox" styleClass="dark-combo" prefWidth="86" />
        <Button text="Refresh" styleClass="accent-button"
                onAction="#refreshChart" />
    </HBox>

    <HBox spacing="14" fillHeight="true" VBox.vgrow="ALWAYS">
        <VBox spacing="10" maxWidth="Infinity" prefWidth="0" HBox.hgrow="ALWAYS">
            <Label text="Weight Trend" styleClass="chart-title-label" />
            <LineChart fx:id="weightChart"
                       styleClass="dark-chart"
                       animated="false"
                       createSymbols="true"
                       VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis label="Date" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Weight (kg)" autoRanging="true" />
                </yAxis>
            </LineChart>

            <VBox styleClass="card" spacing="4" alignment="CENTER" maxWidth="Infinity">
                <Label text="AVERAGE WEIGHT" styleClass="field-label" />
                <Label fx:id="averageWeightLabel" styleClass="card-big-number"
                       style="-fx-font-size: 22;" />
            </VBox>
        </VBox>

        <VBox spacing="10" maxWidth="Infinity" prefWidth="0" HBox.hgrow="ALWAYS">
            <Label text="Workout Load" styleClass="chart-title-label" />
            <LineChart fx:id="workloadChart"
                       styleClass="dark-chart"
                       animated="false"
                       createSymbols="true"
                       VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis label="Date" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Workload" autoRanging="true" />
                </yAxis>
            </LineChart>

            <VBox styleClass="card" spacing="4" alignment="CENTER" maxWidth="Infinity">
                <Label text="AVERAGE WORKLOAD" styleClass="field-label" />
                <Label fx:id="averageWorkloadLabel" styleClass="card-big-number"
                       style="-fx-font-size: 22;" />
            </VBox>
        </VBox>
    </HBox>
</VBox>
